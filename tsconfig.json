{
  "include": ["src/**/*"],
  "compilerOptions": {
    "outDir": "./dist",
    "target": "es2015",
    "lib": ["es2021"],
    "module": "commonjs",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true                            
  }
}